{
  "rules": {
    "daily": {
      ".read": true,
      "$date": {
        ".read": true,
        ".indexOn": ["time"],
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}(_weekly_first)?$/)",
        "$entry": {
          ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid",
          ".validate": "newData.hasChildren(['name', 'time', 'timestamp', 'uid'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20 && newData.val().matches(/^[^<>&\"'`@]+$/)"
          },
          "time": {
            ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
          },
          "bombHits": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
          },
          "par": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600"
          },
          "uid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "timestamp": {
            ".validate": "newData.val() === now"
          },
          "bombHitEvents": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$idx": {
              ".validate": "newData.hasChildren(['t', 'row', 'col'])",
              "t": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "row": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
              "col": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
              "penalty": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "infoValue": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "$other": { ".validate": false }
            }
          },
          "totalBombPenalty": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600"
          },
          "hintEvents": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$idx": {
              ".validate": "newData.hasChildren(['t', 'kind'])",
              "t": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "kind": { ".validate": "newData.isString() && newData.val().length <= 16" },
              "$other": { ".validate": false }
            }
          },
          "rngSeed": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "dailyArchive": {
      ".read": true,
      "$date": {
        ".read": true,
        ".indexOn": ["time"],
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}$/)",
        "$entry": {
          ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid",
          ".validate": "newData.hasChildren(['name', 'time', 'timestamp', 'uid', 'archivePlay'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20 && newData.val().matches(/^[^<>&\"'`@]+$/)"
          },
          "time": {
            ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
          },
          "bombHits": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
          },
          "par": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600"
          },
          "uid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "timestamp": {
            ".validate": "newData.val() === now"
          },
          "archivePlay": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          },
          "cruxViewed": {
            ".validate": "newData.isBoolean()"
          },
          "bombHitEvents": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$idx": {
              ".validate": "newData.hasChildren(['t', 'row', 'col'])",
              "t": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "row": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
              "col": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
              "penalty": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "infoValue": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "$other": { ".validate": false }
            }
          },
          "totalBombPenalty": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600"
          },
          "hintEvents": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$idx": {
              ".validate": "newData.hasChildren(['t', 'kind'])",
              "t": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600" },
              "kind": { ".validate": "newData.isString() && newData.val().length <= 16" },
              "$other": { ".validate": false }
            }
          },
          "rngSeed": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "timed": {
      ".read": true,
      "$entry": {
        ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid",
        ".validate": "newData.hasChildren(['name', 'time', 'timestamp', 'uid'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20 && newData.val().matches(/^[^<>&\"'`@]+$/)"
        },
        "time": {
          ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
        },
        "level": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4"
        },
        "par": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3600"
        },
        "uid": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "newData.val() === now"
        },
        "features": {
          ".validate": "newData.hasChildren(['rows', 'cols', 'totalMines'])"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "dailyMeta": {
      ".read": true,
      "$date": {
        ".write": "auth != null && !data.exists()",
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}(_weekly_first)?$/) && newData.hasChildren(['features', 'writtenAt'])",
        "features": {
          ".validate": "newData.hasChildren(['rows', 'cols', 'totalMines'])"
        },
        "writtenAt": {
          ".validate": "newData.val() === now"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "cruxes": {
      ".read": true,
      "$date": {
        ".write": "auth != null && !data.exists()",
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.hasChildren(['rows', 'cols', 'cells', 'answer', 'sources', 'tier', 'writtenAt'])",
        "rows":   { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 16" },
        "cols":   { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 16" },
        "tier":   { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 3" },
        "cells":  { ".validate": "newData.hasChildren()" },
        "answer": {
          ".validate": "newData.hasChildren(['r', 'c'])",
          "r": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 15" },
          "c": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 15" },
          "$other": { ".validate": false }
        },
        "sources":          { ".validate": "newData.hasChildren() || newData.val() === null" },
        "walls":            { ".validate": "newData.hasChildren() || newData.val() === null" },
        "sentence":         { ".validate": "newData.isString() && newData.val().length <= 300" },
        "sentenceSocratic": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "writtenAt":        { ".validate": "newData.val() === now" },
        "$other":           { ".validate": false }
      }
    },
    "dailyBoard": {
      ".read": true,
      "$date": {
        ".write": "auth != null && !data.exists()",
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}(_weekly_first)?$/) && newData.hasChildren(['rows', 'cols', 'totalMines', 'cells', 'writtenAt'])",
        "rows":          { ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 30" },
        "cols":          { ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 30" },
        "totalMines":    { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 500" },
        "rngSeed":       { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64" },
        "codeVersion":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32" },
        "activeGimmicks":{ ".validate": "newData.hasChildren() || newData.val() === null" },
        "wallEdges":     { ".validate": "newData.hasChildren() || newData.val() === null" },
        "missionTarget":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32" },
        "missionIsPrimary":{ ".validate": "newData.isBoolean()" },
        "gatedCert":       { ".validate": "newData.isBoolean()" },
        "cells": {
          ".validate": "newData.hasChildren()"
        },
        "writtenAt": {
          ".validate": "newData.val() === now"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "weekly": {
      ".read": true,
      "$weekStart": {
        ".validate": "$weekStart.matches(/^\\d{4}-\\d{2}-\\d{2}$/)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['name', 'bestTime', 'timestamp'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20 && newData.val().matches(/^[^<>&\"'`@]+$/)"
          },
          "bestTime": {
            ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600 && (!data.exists() || newData.val() <= data.val())"
          },
          "dayTimes": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$day": {
              ".validate": "$day.matches(/^[0-6]$/) && newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
            }
          },
          "dayBombHits": {
            ".validate": "newData.hasChildren() || newData.val() === null",
            "$day": {
              ".validate": "$day.matches(/^[0-6]$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
            }
          },
          "totalMoves": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 1000"
          },
          "timestamp": {
            ".validate": "newData.val() === now"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "weeklyBoard": {
      ".read": true,
      "$weekStart": {
        ".write": "auth != null && !data.exists()",
        ".validate": "$weekStart.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.hasChildren(['rows', 'cols', 'totalMines', 'cells', 'writtenAt'])",
        "rows":          { ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 30" },
        "cols":          { ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 30" },
        "totalMines":    { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 500" },
        "rngSeed":       { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64" },
        "codeVersion":   { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32" },
        "activeGimmicks":{ ".validate": "newData.hasChildren() || newData.val() === null" },
        "wallEdges":     { ".validate": "newData.hasChildren() || newData.val() === null" },
        "gatedCert":     { ".validate": "newData.isBoolean()" },
        "cells": {
          ".validate": "newData.hasChildren()"
        },
        "writtenAt": {
          ".validate": "newData.val() === now"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "maxCheckpoint": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 120"
        },
        "dailyStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "bestDailyStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lastDailyDate": {
          ".validate": "newData.isString() && newData.val().length === 10"
        },
        "friends": {
          "$friendUid": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)",
            ".validate": "$friendUid !== $uid && newData.hasChildren(['name', 'addedAt'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "addedAt": {
              ".validate": "newData.val() === now"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "dailyHistory": {
          "$date": {
            ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}$/) && newData.hasChildren(['time', 'submittedAt'])",
            "time": {
              ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
            },
            "submittedAt": {
              ".validate": "newData.val() === now"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "weeklyAttempts": {
          "$weekStart": {
            ".validate": "$weekStart.matches(/^\\d{4}-\\d{2}-\\d{2}$/)",
            "dayAttempts": {
              "$day": {
                ".write": "auth != null && auth.uid === $uid && !data.exists()",
                ".validate": "$day.matches(/^[0-6]$/) && newData.hasChildren(['timestamp'])",
                "timestamp": {
                  ".validate": "newData.val() === now"
                },
                "$other": {
                  ".validate": false
                }
              }
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "pushSubscription": {
          ".validate": "newData.hasChildren(['token']) || newData.val() === null",
          "token": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 1024"
          },
          "subscribedAt": {
            ".validate": "newData.val() === now"
          },
          "$other": {
            ".validate": false
          }
        },
        "notificationPrefs": {
          ".validate": "newData.hasChildren(['enabled']) || newData.val() === null",
          "enabled": {
            ".validate": "newData.isBoolean()"
          },
          "hourLocal": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 23"
          },
          "dailyReminder": {
            ".validate": "newData.isBoolean()"
          },
          "streakWarning": {
            ".validate": "newData.isBoolean()"
          },
          "$other": {
            ".validate": false
          }
        },
        "powerUps": {
          ".validate": "newData.hasChildren() || newData.val() === null",
          "$mode": {
            "$type": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
            }
          }
        },
        "lastSeen": {
          ".validate": "newData.hasChildren(['codeVersion', 'at'])",
          "codeVersion": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32" },
          "at": { ".validate": "newData.val() === now" },
          "$other": { ".validate": false }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "errors": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$timestamp": {
          ".validate": "$timestamp.matches(/^[0-9]+$/) && newData.hasChildren(['message', 'codeVersion', 'createdAt'])",
          "message":     { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000" },
          "stack":       { ".validate": "newData.isString() && newData.val().length <= 8000" },
          "url":         { ".validate": "newData.isString() && newData.val().length <= 500" },
          "codeVersion": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 32" },
          "userAgent":   { ".validate": "newData.isString() && newData.val().length <= 500" },
          "isStandalone":{ ".validate": "newData.isBoolean()" },
          "createdAt":   { ".validate": "newData.val() === now" },
          "$other":      { ".validate": false }
        }
      }
    },
    "friendCodes": {
      "$code": {
        ".read": "auth != null && data.child('createdAt').val() > (now - 900000)",
        ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && !newData.exists()))",
        ".validate": "$code.matches(/^[A-Z2-9]{6}$/) && newData.hasChildren(['uid', 'name', 'createdAt'])",
        "uid": {
          ".validate": "newData.isString() && newData.val().length >= 10 && newData.val().length <= 64"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "createdAt": {
          ".validate": "newData.val() === now"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
