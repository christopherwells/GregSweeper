{
  "rules": {
    "daily": {
      "$date": {
        ".read": true,
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}$/)",
        "$entry": {
          ".write": true,
          ".validate": "newData.hasChildren(['name', 'time', 'timestamp'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20"
          },
          "time": {
            ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 3600"
          },
          "bombHits": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
          },
          "timestamp": {
            ".validate": "newData.val() === now"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "maxCheckpoint": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 120"
        },
        "dailyStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "bestDailyStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lastDailyDate": {
          ".validate": "newData.isString() && newData.val().length === 10"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
