.claude/
.playwright-mcp/
.polish/
*.docx
*.png
# Marketing / app assets ship with the repo even though the global *.png
# rule above would otherwise exclude them. Anything not under assets/
# (dev screenshots, .docx exports, ad-hoc captures at repo root) stays
# ignored. The `**` is required so sprites under assets/sprites/ and
# any future subdir also escape the ignore.
!assets/**/*.png

# Dev/CI tooling (Playwright e2e harness) — never shipped. The deployed app
# imports nothing from node_modules.
node_modules/
test-results/
playwright-report/
blob-report/
playwright/.cache/
